GEMINI_API_KEY=your_gemini_api_key_here

# Agent 2: No Reddit API credentials needed — uses scrapi-reddit (public JSON API)

# MongoDB connection URI (docker-compose overrides this automatically)
MONGO_URI=mongodb://localhost:27017

# ngrok tunnel (only needed when using --profile ngrok)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
