GEMINI_API_KEY=your_gemini_api_key_here

# Agent 2: Reddit API credentials
# Create a "script" app at https://www.reddit.com/prefs/apps (no callback URL needed)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# MongoDB connection URI (docker-compose overrides this automatically)
MONGO_URI=mongodb://localhost:27017

# ngrok tunnel (only needed when using --profile ngrok)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
